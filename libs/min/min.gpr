with "min_core.gpr";
with "../../third_party/helios-neorv32-setups/neorv32-hal/neorv32_hal.gpr";

project Min is

   for Languages use ("Ada");
   for Source_Dirs use ("src");
   for Object_Dir use "obj/ada";
   for Create_Missing_Dirs use "True";

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022");
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); -- Symbolic traceback
   end Binder;

end Min;
